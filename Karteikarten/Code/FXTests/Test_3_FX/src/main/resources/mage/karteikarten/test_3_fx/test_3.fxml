<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.GridPane?>


<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.CheckBox?>
<GridPane xmlns:fx="http://javafx.com/fxml"
          fx:controller="mage.karteikarten.test_3_fx.Controller"
          alignment="CENTER" hgap="10" vgap="10">

    <Label text="Your name: "/>
    <TextField fx:id="nameField" GridPane.columnIndex="1" onKeyReleased="#handleKeyReleased"/>
    <Button text="Say hello!" onAction="#onButtonClicked" GridPane.columnIndex="2" fx:id="helloButton"/>
    <Button text="Say bye!" onAction="#onButtonClicked" GridPane.columnIndex="3" fx:id="byeButton"/>
    <CheckBox text="Clear the field after saying hello or bye" GridPane.rowIndex="1" GridPane.columnIndex="1"
              fx:id="clearBox" GridPane.columnSpan="3" onAction="#handleChange"/>

    <Label fx:id="ourLabel" GridPane.rowIndex="2" text="Nothing has happened."/>
</GridPane>
