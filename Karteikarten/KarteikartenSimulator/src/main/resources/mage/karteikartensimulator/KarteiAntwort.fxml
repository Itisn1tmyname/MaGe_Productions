<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>
<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="mage.karteikartensimulator.Controller.Karteikarte"
            prefHeight="750.0" prefWidth="1200.0">

    <top>
        <!--Links: "Antwort", Rechts: Lernfeld -->
        <GridPane style="-fx-border-width: 2; -fx-border-color: grey; -fx-border-style: hidden hidden solid hidden"
                  gridLinesVisible="false">
            <columnConstraints>
                <ColumnConstraints percentWidth="20" halignment="LEFT"/>
                <ColumnConstraints percentWidth="80" halignment="RIGHT"/>
            </columnConstraints>
            <padding>
                <Insets topRightBottomLeft="20"/>
            </padding>

            <Label text="Antwort">
                <font>
                    <Font name="System bold" size="20"/>
                </font>
            </Label>
            <Label text="LF X.X: Testfeld" GridPane.columnIndex="1">
                <font>
                    <Font name="System bold" size="20"/>
                </font>
            </Label>
        </GridPane>
    </top>

    <center>
        <!--Inhalt der Antwort -->
        <Label wrapText="true"
               text="Antworttext
Lorem ipsum dolor sit amet, consetetur sadipscing elitr, sed diam nonumy eirmod tempor invidunt ut labore et dolore magna aliquyam erat, sed diam voluptua. At vero eos et accusam et justo duo dolores et ea rebum. Stet clita kasd gubergren, no sea takimata sanctus est Lorem ipsum dolor sit amet. Lorem ipsum dolor sit amet, consetetur sadipscing elitr, sed diam nonumy eirmod tempor invidunt ut labore et dolore magna aliquyam erat, sed diam voluptua. At vero eos et accusam et justo duo dolores et ea rebum. Stet clita kasd gubergren, no sea takimata sanctus est Lorem ipsum dolor sit amet.">
            <font>
                <Font size="26"/>
            </font>
            <padding>
                <Insets topRightBottomLeft="40"/>
            </padding>
        </Label>
    </center>

    <bottom>
        <!--Bottom_Top: Richtig/Nicht-werten/Falsch; Bottom_Bottom: Tags-->
        <VBox>
            <padding>
                <Insets top="20" right="40" left="20" bottom="10"/>
            </padding>
            <GridPane style="-fx-border-width: 0; -fx-border-color: grey; -fx-border-style: solid hidden hidden hidden"
                      gridLinesVisible="false" hgap="50" alignment="CENTER">
                <columnConstraints>
                    <ColumnConstraints halignment="LEFT"/>
                    <ColumnConstraints percentWidth="33.3" halignment="CENTER"/>
                    <ColumnConstraints halignment="RIGHT"/>
                </columnConstraints>

                <Button text="Frage richtig beantwortet" GridPane.columnIndex="0" prefWidth="300">
                    <font>
                        <Font name="System bold" size="20"/>
                    </font>
                </Button>

                <Button text="Frage nicht werten..." GridPane.columnIndex="1" prefWidth="300">
                    <font>
                        <Font name="System bold" size="20"/>
                    </font>
                </Button>

                <Button text="Falsch beantwortet" GridPane.columnIndex="2" prefWidth="300">
                    <font>
                        <Font name="System bold" size="20"/>
                    </font>
                </Button>
            </GridPane>
            <Label text="#Put your Tags here, damnit!">
                <font>
                    <Font size="18"/>
                </font>
                <padding>
                    <Insets left="20" bottom="10" top="20"/>
                </padding>
            </Label>
        </VBox>
    </bottom>

</BorderPane>
